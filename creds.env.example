# Socrata API credentials for data.calgary.ca
# Create an app token at https://data.calgary.ca/profile/edit/developer_settings
SOCRATA_APP_TOKEN=your_app_token_here

# BLUESKY
ENABLE_BLUESKY=TRUE
BSKY_HANDLE="HANDLE.bsky.social"
BSKY_PASSWORD="APP_PASSWORD"

# MASTODON
ENABLE_MASTODON=TRUE
MASTODON_INSTANCE_URL="https://mastodon.url.here"
MASTODON_ACCESS_TOKEN="your_token_here"

# THREADS
ENABLE_THREADS=FALSE

# X
ENABLE_X=TRUE
X_API_KEY="your_api_key"
X_API_SECRET="your_api_secret"
X_ACCESS_TOKEN="your_access_token"
X_ACCESS_TOKEN_SECRET="your_access_token_secret"
